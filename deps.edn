{:paths ["src"]
 :version "0.1.0"
 ;; langchain-clj provides langchain.db (the Datomic-API-compatible EAV
 ;; store, swappable to a kotoba-server pod). The pure parts of this lib
 ;; (enc/dec*/identity-schema) don't need it; the event-stream helpers
 ;; do. :local/root resolves inside the monorepo; a standalone fork
 ;; overrides with git coordinates.
 :deps {io.github.com-junkawasaki/langchain-clj
        {:local/root "../../kotoba-lang/langchain"}}
 :aliases
 {;; CI / standalone: the langchain-clj artifact's canonical source is the
  ;; PUBLIC kotoba-lang/langchain repo (the org successor its :local/root
  ;; now points at). Override the in-monorepo :local/root with that git
  ;; coordinate (pin == kotoba-lang/langchain main tip) so the suite
  ;; resolves in GitHub Actions, which has no sibling checkout. Compose as
  ;; -M:ci:test / -M:ci:cljs.
  :ci {:replace-deps
       {io.github.com-junkawasaki/langchain-clj
        {:git/url "https://github.com/kotoba-lang/langchain"
         :git/sha "cda206ea2cbe709e134cb7198f85f0eae1993c96"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; PRIMARY gate: the portable suite under ClojureScript.
  ;;   clojure -Sdeps '{:paths ["src" "test"]}' -M:cljs \
  ;;     -m cljs.main --target node -m langchain-store.cljs-runner
  :cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
